# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GNEWS_API_KEY: Required for fetching news from GNews API
GNEWS_API_KEY="MY_GNEWS_API_KEY"

# BREVO_API_KEY: Required for newsletter subscription via Brevo
BREVO_API_KEY="MY_BREVO_API_KEY"

# NOTION_API_KEY: Required for Notion CMS integration
NOTION_API_KEY="MY_NOTION_API_KEY"

# Notion Database IDs
OPPORTUNITIES_DB_ID="MY_OPPORTUNITIES_DB_ID"
COURSES_DB_ID="MY_COURSES_DB_ID"
LEADS_DB_ID="MY_LEADS_DB_ID"

# ── Spotify Music Hub ──────────────────────────────────────────────────────────
# Get these from https://developer.spotify.com/dashboard
# 1. Create an app, copy Client ID + Secret
# 2. Add redirect URI: https://your-domain.vercel.app/auth/spotify/callback
#    (and http://localhost:3000/auth/spotify/callback for local dev)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_REDIRECT_URI="http://localhost:3000/auth/spotify/callback"

# ── YouTube Data API v3 (Music Hub Search) ─────────────────────────────────────
# Required for full YouTube search (title, thumbnail, channel, duration).
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Credentials → Create API Key → restrict to HTTP referrers + YouTube Data API
# 4. Add key below (must be prefixed VITE_ for Vite to expose it to the browser)
# Vercel: Project Settings → Environment Variables → VITE_YOUTUBE_API_KEY
VITE_YOUTUBE_API_KEY="AIzaSy..."
